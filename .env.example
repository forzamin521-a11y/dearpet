# Supabase 프로젝트 설정 (https://supabase.com/dashboard → 프로젝트 → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# 서비스 롤 키 — 절대 클라이언트에 노출 금지 (실장 계정 생성 등 서버 전용)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 이 이메일로 회원가입하면 슈퍼관리자 계정이 된다
SUPER_ADMIN_EMAIL=admin@example.com

# 배포 주소 (동의서 서명 링크 생성에 사용)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------- 알림톡 발송 (docs/alimtalk-relay.md 참고) ----------------
# "aligo"로 설정하고 아래 값이 모두 있으면 실발송, 아니면 시뮬레이션(이력만 기록)
MESSAGING_PROVIDER=fake
# 고정 IP 릴레이 서버(Fly.io)의 발송 엔드포인트와 인증 토큰
ALIMTALK_RELAY_URL=https://your-relay.fly.dev/alimtalk
ALIMTALK_RELAY_TOKEN=your-relay-token
# 알리고에 등록한 DearPet 카카오채널의 발신프로필 키 (senderkey)
ALIGO_SENDER_KEY=your-sender-key
